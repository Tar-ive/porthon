# =============================================================================
# Questline — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# --- Server ---
HOST=0.0.0.0
PORT=8000
WEBUI_TITLE=Questline

# --- Auth ---
PORTTHON_REQUIRE_AUTH=true
PORTTHON_API_KEYS=sk_live_ops_<your_key>
PORTTHON_SESSION_SECRET=<random_secret>

# =============================================================================
# LLM (OpenRouter or any OpenAI-compatible endpoint)
# =============================================================================
LLM_BINDING=openai
LLM_BINDING_API_KEY=sk-or-...
LLM_BINDING_HOST=https://openrouter.ai/api/v1
LLM_MODEL=x-ai/grok-4.1-fast
OPENAI_LLM_MAX_COMPLETION_TOKENS=9000
OLLAMA_LLM_NUM_CTX=32768

# =============================================================================
# Embedding (OpenAI)
# =============================================================================
EMBEDDING_BINDING=openai
EMBEDDING_BINDING_API_KEY=sk-proj-...
EMBEDDING_BINDING_HOST=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIM=3072
EMBEDDING_SEND_DIM=false
EMBEDDING_TOKEN_LIMIT=8192

# =============================================================================
# LightRAG / Knowledge Graph
# =============================================================================
ENABLE_LLM_CACHE=true
ENABLE_LLM_CACHE_FOR_EXTRACT=true
SUMMARY_LANGUAGE=English
MAX_ASYNC=4
MAX_PARALLEL_INSERT=2
RERANK_BINDING=null

# Storage backends (uncomment to switch)
LIGHTRAG_VECTOR_STORAGE=QdrantVectorDBStorage
# LIGHTRAG_VECTOR_STORAGE=NanoVectorDBStorage   # local fallback, no Qdrant needed
LIGHTRAG_GRAPH_STORAGE=Neo4JStorage
# LIGHTRAG_GRAPH_STORAGE=NetworkXStorage        # local fallback, no Neo4j needed

# =============================================================================
# Neo4j (Aura or self-hosted)
# =============================================================================
NEO4J_URI=neo4j+s://<instance>.databases.neo4j.io
NEO4J_QUERY_API_URL=https://<instance>.databases.neo4j.io/db/neo4j/query/v2
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j
NEO4J_CLIENT_ID=
NEO4J_CLIENT_SECRET=
AURA_INSTANCEID=
NEO4J_MAX_CONNECTION_POOL_SIZE=100
NEO4J_CONNECTION_TIMEOUT=30
NEO4J_CONNECTION_ACQUISITION_TIMEOUT=30
NEO4J_MAX_TRANSACTION_RETRY_TIME=30
NEO4J_MAX_CONNECTION_LIFETIME=300
NEO4J_LIVENESS_CHECK_TIMEOUT=30
NEO4J_KEEP_ALIVE=true

# =============================================================================
# Qdrant (cloud or self-hosted)
# =============================================================================
QDRANT_URL=https://<cluster>.us-east-1-1.aws.cloud.qdrant.io
QDRANT_API_KEY=
QDRANT_CLUSTER_ID=
QDRANT_ENDPOINT=https://<cluster>.us-east-1-1.aws.cloud.qdrant.io

# =============================================================================
# Redis (optional — for production KV/doc-status storage)
# =============================================================================
REDIS_URI=redis://localhost:6379
REDIS_SOCKET_TIMEOUT=30
REDIS_CONNECT_TIMEOUT=10
REDIS_MAX_CONNECTIONS=100
REDIS_RETRY_ATTEMPTS=3

# =============================================================================
# Notion
# =============================================================================
NOTION_TOKEN=
NOTION_INTEGRATION_SECRET=
NOTION_WEBHOOK_VERIFICATION_TOKEN=
NOTION_ROOT_PAGE_ID=
NOTION_LEADS_DATA_SOURCE_ID=
NOTION_LEADS_DATABASE_TITLE=🎨 Theo Client Pipeline
NOTION_LEADS_DATA_SOURCE_TITLE=🎨 Theo Client Pipeline

# =============================================================================
# Figma
# =============================================================================
FIGMA_API_KEY=
FIGMA_CLIENT_ID=
FIGMA_CLIENT_SECRET=
FIGMA_WEBHOOK_PASSCODE=

# =============================================================================
# Composio (tool orchestration — Notion, Calendar, Figma integrations)
# =============================================================================
COMPOSIO_API_KEY=

# =============================================================================
# Misc
# =============================================================================
WHITELIST_PATHS=/health,/api/*,/query
